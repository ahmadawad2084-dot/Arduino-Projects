//Objective: Simple application of ultrasonic sensor using LEDs
//Explanation: one side shoots ultra sonic waves at object, other side recieves reflected waves off object
//Explanation Cont.: Meansures time between sending and recieving to calculate distance with speed of sound

//Setting up variables for pins
const int echopin = 10;//Input
const int trigpin = 9; //Output
int smallDelay = 2; //delay value
int largeDelay = 200;
const int redpin = 11; 
const int yellowpin = 12; 
const int greenpin = 13; 


void setup() {
  Serial.begin(9600);       //Started serial monitor
  pinMode(echopin, INPUT);  //Set pin 10 (echopin) to input
  pinMode(trigpin, OUTPUT); //Set pin 9 (trigpin) to output
  pinMode(redpin, OUTPUT);
  pinMode(yellowpin, OUTPUT);
  pinMode(greenpin, OUTPUT);
}


void loop() {

  digitalWrite(trigpin, LOW);  //Setting the trigger off when we begin
  delayMicroseconds(smallDelay);
  digitalWrite(trigpin, HIGH);  //Setting the trigger on
  delayMicroseconds(smallDelay);
  digitalWrite(trigpin, LOW);  //Setting the trigger off when we begin
  delayMicroseconds(smallDelay * 5);
  
//Reading the Echo's duration
  long duration = pulseIn(echopin, HIGH); //long is a class for variables, like int, float, ect... difference is that it holds more bytes of data in it than an int

//Calculation
  float distance = duration / 58.0;

  Serial.print("Distance: ");
  Serial.print(distance);
  Serial.println(" cm");

  delay(largeDelay);


  if (distance <=10){
    digitalWrite(redpin, HIGH);
    digitalWrite(yellowpin, LOW);
    digitalWrite(greenpin, LOW);
  }
  else if (distance >= 11 && distance <= 30){
    digitalWrite(redpin, LOW);
    digitalWrite(yellowpin, HIGH);
    digitalWrite(greenpin, LOW);    
    }

    else {
      digitalWrite(redpin, LOW);
      digitalWrite(yellowpin, LOW);
      digitalWrite(greenpin, HIGH);

    }
}
